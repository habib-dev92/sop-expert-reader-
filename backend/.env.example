# Backend Environment Configuration
# Copy this file to .env and adjust values

OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_REFERER=https://sop-expert-ai.vercel.app
OPENAI_APP_TITLE=SOP Expert AI
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","https://*.vercel.app"]
JWT_SECRET_KEY=change-this-to-a-secure-random-secret-in-production
ADMIN_EMAIL=your-email@example.com
FRONTEND_URL=http://localhost:3000

# SMTP settings for password reset (leave empty to show link on screen)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
